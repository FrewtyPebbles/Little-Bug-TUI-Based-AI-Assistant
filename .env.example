# ── Backend Config ──────────────────────────────────────────
ENVIRONMENT_TYPE=DEV

# ── Keycloak (Auth) ─────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080/
# For Docker: KEYCLOAK_URL=http://keycloak:8080/

KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_API_CLIENT_SECRET=change-me-to-a-real-secret

# ── Auth Database (Postgres for Keycloak) ──────────────────
AUTH_DB_USERNAME=keycloak
AUTH_DB_PASSWORD=keycloak

# ── Application Database (Postgres + pgvector) ─────────────
APP_DB=application
APP_DB_USERNAME=app_user
APP_DB_PASSWORD=app_pass
APP_DB_HOST=localhost
# For Docker: APP_DB_HOST=postgres-application

# ── Document Database (Cassandra) ──────────────────────────
CASSANDRA_HOST=cassandra
CASSANDRA_PASSWORD=password
CASSANDRA_USER=user

# ── Cache (Redis) ───────────────────────────────────────────
REDIS_PASSWORD=redis_pass

# ── Server ──────────────────────────────────────────────────
BACKEND_PORT=8000
